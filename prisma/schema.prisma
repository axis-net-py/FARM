generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────

enum Role {
  SOVEREIGN
  ADMIN
  OPERATOR
  AUDITOR
}

enum Currency {
  PYG
  USD
  BRL
}

enum TransactionType {
  RECEIVABLE
  PAYABLE
  TRANSFER
}

enum InvoiceType {
  PURCHASE
  SALES
}

enum InvoiceStatus {
  DRAFT
  APPROVED
  CANCELLED
  PENDING
}

enum MovementType {
  ENTRADA
  SAIDA
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum TaxType {
  IVA_10
  IVA_5
  EXENTO
}

// ─── Tenant ─────────────────────────────────────────────────

model Tenant {
  id                String   @id @default(cuid())
  name              String
  businessName      String?
  ruc               String?
  tradeName         String?
  establishment     String?  @default("001")
  emissionPoint     String?  @default("001")
  address           String?
  economicActivity  String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  users             User[]
  customers         Customer[]
  suppliers         Supplier[]
  products          Product[]
  invoices          CommercialInvoice[]
  exchangeRates     ExchangeRate[]
  accounts          Account[]
  transactions      Transaction[]
  permissions       Permission[]
  journalEntries    JournalEntry[]
  auditLogs         AuditLog[]
  harvests          Harvest[]
  plots             Plot[]
  vehicles          Vehicle[]
  employees         Employee[]
  contracts         Contract[]
  vehicleLogs       VehicleLog[]
  plotApplications  PlotApplication[]
  silos             Silo[]
  siloMovements     SiloMovement[]
  soilAnalyses      SoilAnalysis[]
}

// ─── User ───────────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  password      String
  role          Role     @default(OPERATOR)
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  emailVerified DateTime?
  createdAt     DateTime @default(now())

  @@index([tenantId])
}

// ─── Customer ───────────────────────────────────────────────

model Customer {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  name         String
  document     String?
  documentType String?  // RUC, CI, CPF, CNPJ
  email        String?
  phone        String?
  address      String?
  city         String?
  country      String?  @default("PY")
  category     String?  @default("retail") // retail, wholesale, vip
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  invoices     CommercialInvoice[]

  @@index([tenantId])
}

// ─── Supplier ───────────────────────────────────────────────

model Supplier {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  name          String
  businessName  String?
  document      String?
  documentType  String?  // RUC, CI, CPF, CNPJ
  email         String?
  phone         String?
  address       String?
  city          String?
  country       String?  @default("PY")
  category      String?  @default("retail")
  isActive      Boolean  @default(true)
  paymentTerms  String?  // e.g. "30 days", "Net 60"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  purchaseInvoices CommercialInvoice[]

  @@index([tenantId])
}

// ─── Product ────────────────────────────────────────────────

model Product {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  sku          String
  name         String
  price        Decimal  @db.Decimal(12, 2)
  cost         Decimal  @db.Decimal(12, 2) @default(0)
  currency     Currency @default(PYG)
  unit         String   @default("un")
  taxType      TaxType  @default(IVA_10)
  currentStock Decimal  @db.Decimal(10, 2) @default(0)
  minStock     Decimal  @db.Decimal(10, 2) @default(0)
  isActive     Boolean  @default(true)
  tags         String?
  isService    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  movements    InventoryMovement[]
  invoiceItems InvoiceItem[]
  applications PlotApplication[]

  @@unique([tenantId, sku])
  @@index([tenantId])
}

// ─── Commercial Invoice ─────────────────────────────────────

model CommercialInvoice {
  id             String       @id @default(cuid())
  tenantId       String
  tenant         Tenant       @relation(fields: [tenantId], references: [id])
  type           InvoiceType
  status         InvoiceStatus @default(APPROVED)
  documentNumber String?
  timbrado       String?
  sifenCdc       String?
  sifenXmlUrl    String?
  sifenStatus    String?
  attachmentUrl  String?
  customerId     String?
  customer       Customer?    @relation(fields: [customerId], references: [id])
  supplierId     String?
  supplier       Supplier?    @relation(fields: [supplierId], references: [id])
  issuedAt       DateTime     @default(now())
  dueDate        DateTime?
  currency       Currency     @default(PYG)
  exchangeRate   Decimal      @db.Decimal(12, 4) @default(1)
  totalAmount    Decimal      @db.Decimal(12, 2) @default(0)
  totalUSD       Decimal?     @db.Decimal(12, 2)
  totalIva10     Decimal      @db.Decimal(12, 2) @default(0)
  totalIva5      Decimal      @db.Decimal(12, 2) @default(0)
  totalExento    Decimal      @db.Decimal(12, 2) @default(0)
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  items          InvoiceItem[]
  movements      InventoryMovement[]

  @@index([tenantId])
  @@index([customerId])
  @@index([supplierId])
}

// ─── Invoice Item ───────────────────────────────────────────

model InvoiceItem {
  id                  String            @id @default(cuid())
  commercialInvoiceId String
  commercialInvoice   CommercialInvoice @relation(fields: [commercialInvoiceId], references: [id])
  productId           String
  product             Product           @relation(fields: [productId], references: [id])
  sku                 String?
  quantity            Decimal           @db.Decimal(10, 2)
  unitPrice           Decimal           @db.Decimal(12, 2)
  totalPrice          Decimal           @db.Decimal(12, 2)
  taxType             TaxType           @default(IVA_10)
  taxBase             Decimal           @db.Decimal(12, 2) @default(0)
  taxAmount           Decimal           @db.Decimal(12, 2) @default(0)
  cost                Decimal?          @db.Decimal(12, 2)

  @@index([commercialInvoiceId])
  @@index([productId])
}

// ─── Inventory Movement ─────────────────────────────────────

model InventoryMovement {
  id                  String            @id @default(cuid())
  tenantId            String
  productId           String
  product             Product           @relation(fields: [productId], references: [id])
  type                MovementType
  quantity            Decimal           @db.Decimal(10, 2)
  unitCost            Decimal?          @db.Decimal(12, 2)
  totalCost           Decimal?          @db.Decimal(12, 2)
  reason              String?
  commercialInvoiceId String?
  commercialInvoice   CommercialInvoice? @relation(fields: [commercialInvoiceId], references: [id])
  createdAt           DateTime          @default(now())

  @@index([tenantId])
  @@index([productId])
}

// ─── Exchange Rate ──────────────────────────────────────────

model ExchangeRate {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  ratePYGtoUSD Decimal @db.Decimal(12, 4)
  ratePYGtoBRL Decimal @db.Decimal(12, 4)
  date        DateTime @default(now())
  source      String   @default("manual")
  isManual    Boolean  @default(false)

  @@index([tenantId])
  @@index([date])
}

// ─── Account (Chart of Accounts) ────────────────────────────

model Account {
  id       String      @id @default(cuid())
  tenantId String
  tenant   Tenant      @relation(fields: [tenantId], references: [id])
  code     String
  namePt   String
  nameEs   String
  type     AccountType
  isActive Boolean     @default(true)

  journalLines JournalLine[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

// ─── Transaction ────────────────────────────────────────────

model Transaction {
  id           String          @id @default(cuid())
  tenantId     String
  tenant       Tenant          @relation(fields: [tenantId], references: [id])
  type         TransactionType
  entityId     String
  currency     Currency        @default(PYG)
  amount       Decimal         @db.Decimal(12, 2)
  exchangeRate Decimal         @db.Decimal(12, 4) @default(1)
  totalPyg     Decimal         @db.Decimal(12, 2)
  category     String?
  createdAt    DateTime        @default(now())

  @@index([tenantId])
}

// ─── Permission ─────────────────────────────────────────────

model Permission {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  action   String
  role     Role

  @@unique([action, role, tenantId])
  @@index([tenantId])
}

// ─── Journal Entry ──────────────────────────────────────────

model JournalEntry {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  number        String
  date          DateTime
  description   String
  status        String   @default("DRAFT") // POSTED, DRAFT, VOIDED
  referenceType String?
  referenceId   String?
  postedAt      DateTime?
  createdBy     String?
  createdAt     DateTime @default(now())

  lines         JournalLine[]

  @@index([tenantId])
}

// ─── Journal Line ───────────────────────────────────────────

model JournalLine {
  id              String       @id @default(cuid())
  journalEntryId  String
  journalEntry    JournalEntry @relation(fields: [journalEntryId], references: [id])
  accountId       String
  account         Account      @relation(fields: [accountId], references: [id])
  type            String       // DEBIT, CREDIT
  amount          Decimal      @db.Decimal(12, 2)
  currency        String       @default("PYG")
  exchangeRate    Decimal      @db.Decimal(12, 4) @default(1)
  amountUSD       Decimal?     @db.Decimal(12, 2)
  createdAt       DateTime     @default(now())

  @@index([journalEntryId])
  @@index([accountId])
}

// ─── Audit Log ──────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  userId    String?
  action    String
  entity    String?
  entityId  String?
  details   Json?
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([entity, entityId])
}

// ─── Agricultural Modules ───────────────────────────────────

model Harvest {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  name        String
  cropType    String   // soja, milho, trigo, etc.
  startDate   DateTime
  endDate     DateTime
  status      String   @default("ACTIVE") // ACTIVE, COMPLETED, PLANNED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  plots       Plot[]
  contracts   Contract[]
  applications PlotApplication[]
  siloMovements SiloMovement[]

  @@index([tenantId])
}

model Plot {
  id           String            @id @default(cuid())
  tenantId     String
  tenant       Tenant            @relation(fields: [tenantId], references: [id])
  name         String
  area         Decimal           @db.Decimal(10, 2)
  unit         String            @default("HECTARE") // HECTARE, ALQUEIRE
  currentCrop  String?
  status       String            @default("PLANTED") // FALLOW, PLANTED, PREPARING
  harvestId    String?
  harvest      Harvest?          @relation(fields: [harvestId], references: [id])
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  applications PlotApplication[]
  soilAnalyses SoilAnalysis[]

  @@index([tenantId])
  @@index([harvestId])
}

model SoilAnalysis {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  plotId          String
  plot            Plot     @relation(fields: [plotId], references: [id])
  date            DateTime
  ph              Decimal? @db.Decimal(4, 2)
  phosphorus      Decimal? @db.Decimal(8, 2) // P, mg/dm³
  potassium       Decimal? @db.Decimal(8, 2) // K, cmolc/dm³
  organicMatter   Decimal? @db.Decimal(5, 2) // %
  recommendation  String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId])
  @@index([plotId])
}

model PlotApplication {
  id         String    @id @default(cuid())
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id])
  plotId     String
  plot       Plot      @relation(fields: [plotId], references: [id])
  harvestId  String?
  harvest    Harvest?  @relation(fields: [harvestId], references: [id])
  productId  String
  product    Product   @relation(fields: [productId], references: [id])
  quantity   Decimal   @db.Decimal(10, 2)
  totalCost  Decimal?  @db.Decimal(12, 2)
  date       DateTime
  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id])
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([tenantId])
  @@index([plotId])
}

model Vehicle {
  id               String       @id @default(cuid())
  tenantId         String
  tenant           Tenant       @relation(fields: [tenantId], references: [id])
  name             String
  type             String       // trator, colheitadeira, pulverizador, caminhao, etc.
  plate            String?
  status           String       @default("OPERATIONAL") // OPERATIONAL, MAINTENANCE, OUT_OF_SERVICE
  currentReading   Decimal?     @db.Decimal(12, 2)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  logs             VehicleLog[]

  @@index([tenantId])
}

enum VehicleLogType {
  MAINTENANCE
  FUEL
}

model VehicleLog {
  id              String         @id @default(cuid())
  tenantId        String
  tenant          Tenant         @relation(fields: [tenantId], references: [id])
  vehicleId       String
  vehicle         Vehicle        @relation(fields: [vehicleId], references: [id])
  type            VehicleLogType
  date            DateTime
  odometerOrHours Decimal?       @db.Decimal(12, 2)
  employeeId      String?
  employee        Employee?      @relation(fields: [employeeId], references: [id])
  notes           String?
  liters          Decimal?       @db.Decimal(10, 2)
  fuelCost        Decimal?       @db.Decimal(12, 2)
  description     String?
  maintenanceCost Decimal?       @db.Decimal(12, 2)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([tenantId])
  @@index([vehicleId])
}

model Employee {
  id          String       @id @default(cuid())
  tenantId    String
  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  name        String
  role        String       // tratorista, agronomo, operador, auxiliar, etc.
  phone       String?
  status      String       @default("ACTIVE") // ACTIVE, INACTIVE, LEAVE
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  vehicleLogs      VehicleLog[]
  plotApplications PlotApplication[]

  @@index([tenantId])
}

model Contract {
  id             String    @id @default(cuid())
  tenantId       String
  tenant         Tenant    @relation(fields: [tenantId], references: [id])
  contractNumber String
  harvestId      String?
  harvest        Harvest?  @relation(fields: [harvestId], references: [id])
  siloName       String
  grainType      String    // soja, milho, trigo, etc.
  quantity       Decimal   @db.Decimal(12, 2)
  unit           String    @default("TON") // TON, BAG, KG
  pricePerUnit   Decimal   @db.Decimal(12, 2)
  currency       Currency  @default(USD)
  status         String    @default("ACTIVE") // ACTIVE, COMPLETED, CANCELLED
  deliveryDate   DateTime?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  siloMovements  SiloMovement[]

  @@index([tenantId])
  @@index([harvestId])
}

model Silo {
  id           String         @id @default(cuid())
  tenantId     String
  tenant       Tenant         @relation(fields: [tenantId], references: [id])
  name         String
  capacity     Decimal        @db.Decimal(12, 2)
  unit         String         @default("TON") // TON, BAG, KG
  currentStock Decimal        @db.Decimal(12, 2) @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  movements    SiloMovement[]

  @@index([tenantId])
}

enum SiloMovementType {
  IN
  OUT
}

model SiloMovement {
  id           String           @id @default(cuid())
  tenantId     String
  tenant       Tenant           @relation(fields: [tenantId], references: [id])
  siloId       String
  silo         Silo             @relation(fields: [siloId], references: [id])
  type         SiloMovementType
  quantity     Decimal          @db.Decimal(12, 2)
  date         DateTime
  harvestId    String?
  harvest      Harvest?         @relation(fields: [harvestId], references: [id])
  contractId   String?
  contract     Contract?        @relation(fields: [contractId], references: [id])
  moisture     Decimal?         @db.Decimal(5, 2)
  qualityGrade String?
  notes        String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([tenantId])
  @@index([siloId])
}
