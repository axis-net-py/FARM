{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@axis/core/*": ["../../packages/core/*"],
      "@/packages/core/*": ["../../packages/core/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
